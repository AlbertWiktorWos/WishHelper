# In all environments, the following files are loaded if they exist,
# the latter taking precedence over the former:
#
#  * .env                contains default values for the environment variables needed by the app
#  * .env.local          uncommitted file with local overrides
#  * .env.$APP_ENV       committed environment-specific defaults
#  * .env.$APP_ENV.local uncommitted environment-specific overrides
#
# Real environment variables win over .env files.
#
# DO NOT DEFINE PRODUCTION SECRETS IN THIS FILE NOR IN ANY OTHER COMMITTED FILES.
# https://symfony.com/doc/current/configuration/secrets.html
#
# Run "composer dump-env prod" to compile .env files for production use (requires symfony/flex >=1.2).
# https://symfony.com/doc/current/best_practices.html#use-environment-variables-for-infrastructure-configuration

###> symfony/framework-bundle ###
APP_SECRET=4ee93b881bb8d5fc2b401864fc466003
###< symfony/framework-bundle ###

DOCUMENTROOT=.
#user name
DB_USER="wh_admin"
#root password
DB_ROOT_PASSWORD="tester"
#user password
DB_PASSWORD="wh_tester"
#name of database
DB_DB="wh_database"
#name of container
DB_HOST="wh_database:3306"
#DB version
DB_VERSION=8.0

###> doctrine/doctrine-bundle ###
DATABASE_URL="mysql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}/${DB_DB}?serverVersion=8.0"
###< doctrine/doctrine-bundle ###

###> symfony/mailer ###
MAILER_DSN=null://default
MAIL_SENDER=test@test.com
###< symfony/mailer ###

### XDEBUG_DISABLE
XDEBUG_MODE=debug
XDEBUG_START_WITH_REQUEST=yes

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

###> symfony/lock ###
# Choose one of the stores below
LOCK_DSN=flock
###< symfony/lock ###

## REDIS
REDIS_URL=redis://redis:6379

## CURRENCY_API
CURRENCY_API_KEY=xxxxx
CURRENCY_API_DEFAULT_CURRENCY=USD
###> symfony/messenger ###
RABBITMQ_USER=wh_user
RABBITMQ_PASS=wh_pass
MESSENGER_TRANSPORT_DSN=amqp://${RABBITMQ_USER}:${RABBITMQ_PASS}@rabbitmq:5672/%2f/messages
###< symfony/messenger ###

### AI URL
AI_BASE_URL=https://generativelanguage.googleapis.com

# LOCAL URL
SITE_BASE_SCHEME=http
SITE_BASE_HOST=localhost
SITE_BASE_PORT=8080
SITE_BASE_URL=${SITE_BASE_SCHEME}://${SITE_BASE_HOST}:${SITE_BASE_PORT}

###> symfony/mercure-bundle ###
# See https://symfony.com/doc/current/mercure.html#configuration
# The URL of the Mercure hub, used by the app to publish updates (can be a local URL)
MERCURE_URL=http://mercure/.well-known/mercure
# The public URL of the Mercure hub, used by the browser to connect
MERCURE_PUBLIC_URL=${SITE_BASE_SCHEME}://${SITE_BASE_HOST}:3000/.well-known/mercure
# The secret used to sign the JWTs
MERCURE_JWT_SECRET=66f9388038fdc5a1cab8981a3af3b398e1603bc713a30fe99c32fe76e29c1e76
MERCURE_CORS_ORIGINS="http://localhost:8080 http://127.0.0.1:8080 ${SITE_BASE_URL}"
###< symfony/mercure-bundle ###
